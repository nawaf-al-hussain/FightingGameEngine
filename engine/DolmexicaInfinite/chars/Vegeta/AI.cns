[Statedef 8040,AIジャンプ・予備動作]
type = S
physics = S
anim = 40
ctrl = 0
sprpriority = 1

[State 8040, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 8040, 2]
type = VarSet
trigger1 = Time = 0
var(5) = 0

[State 8040, longjump];ロングジャンプ
type = VarSet
trigger1 = 1
var(5) = 1

[State 8040, 4]
type = VarSet
trigger1 = 1
sysvar(1) = 1

[State 8040, 6]
type = VelSet
trigger1 = AnimTime = 0
x = const(velocity.jump.fwd.x)
y = const(velocity.jump.y)

[State 8040, 10]
type = ChangeState
trigger1 = AnimTime = 0
value = 8050

