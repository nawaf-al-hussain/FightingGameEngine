;CPU用しゃがみガード
[Statedef 131]
type    = C
physics = C

[State 131, コモン]
type = ChangeAnim
trigger1 = Anim != 131
value = 131

[State 131, CPU用含む]
type = ChangeState
trigger1 = Var(59) = 0
trigger1 = command != "holddown"
trigger2 = Var(59) = [1,2]
trigger2 = p2statetype = A
trigger2 = time = 1
value = 130

[State 131, コモン]
type = ChangeState
trigger1 = command != "holdback"
trigger2 = !inguarddist
value = 140

