;HYPER 1
[Statedef 3000]
type    = S
movetype= I
physics = S
velset = 0,0
anim = 3000
ctrl = 0
sprpriority = 1

[State 3000, Reset DHC]
type= varset
trigger1= var(57)
trigger1= AnimelemTime(5)<0
var(57)= 0

[State 1000, Vari�vel de for�a]
type = VarSet
trigger1 = !time
v = 20
value = 2;ifelse (command = "qcf_z",2,(ifelse(command = "qcf_y",1,0)))

[State 3000, Corner Push]
type= varset
trigger1= fvar(5)
trigger1= 1
fvar(5)= 0

[State 3000]
type=SuperPause
trigger1=!time
time=45
anim=s6050
sound=S2000,0
pos=32,-66
movetime=2
poweradd=-1000

[State 0, Helper]; ====================================calls hyperbg
type = Helper
trigger1 =  !time
helpertype = normal ;player
name ="Hyper fx"
ID = 96000
stateno = 96000
pos = 0,0
postype = left    ;p2,front,back,left,right
facing = 1
keyctrl = 0
ownpal = 1
supermovetime = 0
pausemovetime = 0

[State 3000]
type=PosSet
trigger1=1
y=0

[State 3000]
type=NotHitBy
Trigger1=animelemtime(4)>=7 && animelemtime(7)<0
value=SCA
Time=1

[State 0, PlaySnd]
type = PlaySnd
trigger1 = !time
value = S3001,0

[State 0, Helper]
type = Helper
trigger1 = time>8&time%3=0
helpertype = normal ;player
name = "batrang" 
ID = 1005
stateno = 1008
pos = 25,-85 + random%50
postype = p1    ;p2,front,back,left,right
facing = 1
keyctrl = 0
ownpal = 1

[State 3000, 7]
type = ChangeState
trigger1 = Time=100
value = 3001
ctrl = 0

