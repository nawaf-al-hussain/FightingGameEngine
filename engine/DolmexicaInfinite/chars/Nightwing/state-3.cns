[State -3,Recovery Roll forward]
type = ChangeState
triggerall=var(49)!=1&&life!=0
trigger1=alive&&stateno=5120
trigger1=var(53)=2
trigger1=var(40)=1;||NumPartner && NumPartner && partner,var(40)=1
trigger1=time=[0,3]
value=940
ctrl=1

[State -3,Recovery Roll back]
type = ChangeState
triggerall=var(49)!=1&&life!=0
trigger1=alive&&stateno=5120
trigger1=var(53)=2
trigger1=var(40)=2;||NumPartner && NumPartner && partner,var(40)=2
trigger1=time=[0,3]
value=941
ctrl=1

[State -3,Tech Hit Recovery Roll Forward]
type=ChangeState
value=942
triggerall=var(49)!=1&&life!=0
trigger1=alive&&Roundstate=2
trigger1=var(53)=2
trigger1=(StateNo = 5030) || (StateNo = 5035) || (StateNo = 5050) || (StateNo = 5071)
trigger1=var(40)=1;||NumPartner && NumPartner && partner,var(40)=1
;trigger1=time=[0,1]
trigger1=pos Y > -10
trigger1=vel Y > 0
trigger1=anim=5052||anim=5060

[State -1,Tech Hit Recovery Roll Back]
type=ChangeState
value=943
triggerall=var(49)!=1&&life!=0
trigger1=alive&&Roundstate=2
trigger1=var(53)=2
trigger1=(StateNo = 5030) || (StateNo = 5035) || (StateNo = 5050) || (StateNo = 5071)
