;===============================================================================================
;This controller plays a sound everytime KFM lands from a jump or from his back-dash.
[State -3, Landing Sound]
type = PlaySnd
triggerall = Time = 1
trigger1 = stateno = 52 ;Jump land
trigger2 = stateno = 106 ;Run-back land
value = 47, 0

;[State -3,PlaySnd Partner Winscreen]
;type = PlaySnd
;trigger1 = NumPartner && NumPartner && partner,stateno=189
;trigger1 = Time = 1
;value = 180, 0
;channel=0
;===============================================================================================
;SUPER JUMP STATES
[State -3,veladd]
type = Veladd
triggerall =command = "holdfwd"
triggerall = prevstateno = 111 ; the superjumo state
trigger1 = stateno = 50; jump state
x = .05 ; maybe you need to modify these value

[State -3,veladd]
type = Veladd
triggerall =command = "holdback"
triggerall = prevstateno = 111
trigger1 = stateno = 50
x = -.05
;===============================================================================================

[State -3, Fake helper];FOR FIRST ATTACK
type = helper
trigger1 = roundstate = 2 && !numhelper(8500)
helpertype = Normal
id = 8500
pos = 0,0
postype = p1
name = "Fake Helper"
stateno = 8500
supermovetime = 9999999999
pausemovetime = 9999999999

[State -3, Dummy Helper];FOR PERFECT!
type = helper
triggerall = !numpartner
trigger1 = time = 1 && !numhelper(8550)
helpertype = normal
name = "Dummy Helper"
ID = 8550
stateno = 8550
;pos = 0,-99999999999999999
postype = left    ;p2,front,back,left,right
ownpal = 0
supermovetime = 999999999999
pausemovetime = 999999999999
ignorehitpause = 1
persistent = 0
;=============================================================================================
;           States that are executed when in self's state file (use statedef -3)
;=============================================================================================


[State -3: ChangeState]
type = ChangeState
triggerall = (Var(0)) && (StateType != A) && (Ctrl) && (EnemyNear, Facing != Facing)
trigger1 = (P2StateType != C) && (P2MoveType = A) && ((InGuardDist) || (EnemyNear, NumProj > 0))
trigger2 = (p2bodydist X <= 150) && (Facing = 1) && (EnemyNear, Facing = -1) && (P2MoveType = A)
trigger3 = (p2bodydist X <= 150) && (Facing = -1) && (EnemyNear, Facing = 1) && (P2MoveType = A)
trigger4 = (stateno=0) && (prevstateno=5120) && (EnemyNear, Stateno=[3000,3999])
value = 130

[State -3: ChangeState]
type = ChangeState
triggerall = (Var(0)) && (StateType != A) && (Ctrl) && (EnemyNear, Facing != Facing)
trigger1 = (P2StateType = C) && (P2MoveType = A) && ((InGuardDist) || (EnemyNear, NumProj > 0))
value = 131

[State -3: ChangeState]
type = ChangeState
triggerall = (Var(0)) && (StateType = A) && (Ctrl) && (EnemyNear, Facing != Facing)
trigger1 = (P2MoveType = A) && ((InGuardDist) || (EnemyNear, NumProj > 0))
trigger1 = (vel x !=const(velocity.airjump.fwd.x)) && (vel y >=1) && (p2statetype=A)
value = 132

;===============================================================================================
;                                          Corner Push 
;===============================================================================================
[State -3, Corner Push1]
type= varset
trigger1= fvar(5)
trigger1= numtarget
trigger1= target,hitover || (target,gethitvar(hitshaketime)>0 && target,time<=0)
fvar(5)= 0

[State -3, Corner Push2]
type= varset
trigger1= movecontact=1 && numtarget
fvar(5)= target,gethitvar(xvel)
ignorehitpause= 1

[State -3, Corner Push4]
type= posadd
triggerall= fvar(5)
triggerall= statetype!=L && numtarget
triggerall= (target,statetype!=L)
triggerall= !hitpausetime && target,gethitvar(hitshaketime)<=0
trigger1= target,frontedgebodydist<=abs(target,vel x)
trigger1= (target,gethitvar(xvel) * target,facing)>0
trigger2= target,backedgebodydist<=abs(target,vel x)
trigger2= (target,gethitvar(xvel) * target,facing)<0
x= ifelse(target,frontedgebodydist<=0, -1, 1) * (target,facing) * fvar(5)

[State -3, Corner Push5]
type= varset
trigger1= numtarget
trigger1= target,gethitvar(hitshaketime)<=0
fvar(5)= fvar(5)*.85
;================================================================================================
;                                         COLLAPSE/CHEAP DEATH
;================================================================================================
[State -3, Cheap KO]
type=changestate
;trigger1=NumPartner && (NumPartner && partner,stateno!=4512)
trigger1=!alive && (stateno=[5000,5010])
trigger1=(prevstateno=[130,131]) || (prevstateno=[140,141]) || (prevstateno=[150,153])
value=5130
ignorehitpause=1
;===============================================================================================
;                                       Variable State Set 
;===============================================================================================
;THIS PREVENTS YOU FROM BEING ABLE TO TAG WHEN THE FIGHT IS OVER
[State -3, PARTNER TAG MODE NOT ACTIVE]
type=varset
trigger1=roundstate >=3
var(51)=0

;THIS ACTIVATES THE TAG MODE IN SIMULTANIOUS MODE
[State -3, activate tag]
type = VarSet
trigger1 = teammode = simul
trigger1 = roundstate < 1
trigger1 = time = [0,1]
v = 51
value = 1

;THIS TAKES AWAY CONTROL 
[state -3]
type = ctrlset
trigger1 = var(52) = 1
value = 0

;THIS JUST LET YOU SEE YOUR PARTNERS STATENO
;[State -3, PARTNER STATENO]
;type=varset
;triggerall = NumPartner
;trigger1=1
;var(50)=(NumPartner && partner,stateno)

;THIS MAKES SURE THE DHC IS RESET AND NOT ACTIVE IF YOU DO NOT REACH THE VAR(14) RESET IN THE HYPER STATE
;[State -3, DHC RESET]
;type=varset
;triggerall = NumPartner
;trigger1=(stateno=0)||(NumPartner && partner,stateno=0)
;var(14)=0

;THIS SETS VARIABLE FOR PARTNER TO YOUR VARIABLE
[state -3]
type =NULL; varset
triggerall = NumPartner
trigger1 = ID > NumPartner && partner, ID
v = 31
value = (NumPartner && partner,var(31))

;THIS SETS YOU AS THE FIRST PLAYER
;[State -3]
;type = Varset
;triggerall = numpartner != 0
;trigger1 = var(53)=0
;trigger2 = roundstate = 0 
;v = 53
;value=1+((NumPartner && partner, id) < id)

;THIS KEEPS YOUR PARTNER FROM HAVING CONTROL SO HE USES YOUR COMMANDS
[State -3, 2nd character always no ctrl]
type = CtrlSet
trigger1 = Var(53)= 2 
value =0
ignorehitpause = 1

;THIS TAKES CONTROL AWAY FROM YOUR PARTNER 
[State -3, 2nd character always no ctrl]
type = VarSet
triggerall = Var(53)=2
trigger1 = (StateNo !=0 && StateNo !=10 &&StateNo !=11 &&StateNo!=12 &&StateNo!=20 &&(StateNo!=[50,51])&&stateno!=100)
trigger1 = (StateNo !=120 &&StateNo !=130 &&StateNo !=131 &&StateNo !=460 &&StateNo !=5040)
trigger1 = StateNo !=52
trigger2 = movetype =h
trigger3 = StateNo = 5 && time = 0
var(54)=0 

;THIS KEEPS YOUR PARTNER FROM HAVING CONTROL SO HE USES YOUR COMMANDS
[State -3, 2nd character always no ctrl]
type = VarSet
triggerall = movetype !=h
triggerall = Var(53)=2 && RoundState = 2
trigger1 = (StateNo =0 ||StateNo =10 ||StateNo =11 ||stateno=12 ||stateno=20 ||(stateno=[50,51])||stateno=100)
trigger2 = (StateNo =120 ||StateNo =130 ||StateNo =131 ||StateNo =460 ||StateNo =5040)
trigger3 = StateNo = 5 && time = 1
var(54)=1

;THIS KEEPS YOUR PARTNERS DHC ACTIVATOR THE SAME AS YOURS WHEN IN STATE 4512
;[state -3, DHC Activator]
;type=varset
;triggerall = NumPartner
;trigger1=1
;v=14
;value=(NumPartner && partner,var(14))

;THIS RESETS YOUR PARTNERS DHC ACTIVATOR
[state -3, DHC Safety Reset]
type=varset
trigger1=var(14)!=0&&statetype!=A&&stateno=[0,2999]
v=14
value=0

;THIS SETS VARIABLE FOR PARTNER TO YOUR VARIABLE
;[state -3, No Spam]
;type=varset
;triggerall = NumPartner
;trigger1=ID>NumPartner && partner,ID
;v=19
;value=(NumPartner && partner,var(19))
;===============================================================================================
;                                    Normal & Special KO States 
;===============================================================================================
[State -3, VarSet]
type=VarSet
trigger1=roundstate=2
var(58)=0

[state -3, VarSet]
type=VarSet
triggerall=var(58)=0
triggerall=winko
trigger1=(stateno=[200,661])
trigger2=(stateno=[1000,1999])
trigger3=(stateno=4501)||(stateno=4510)
var(58)=1
ignorehitpause=1

[state -3, helper]
type=null;helper
triggerall=NumHelper(9650)=0
triggerall=var(58)=1
trigger1=numtarget
stateno=9650
ID=9650
pos=0,0
postype=p1
helpertype=normal
name="ko-sounds"
pausemovetime=999
supermovetime=999
ignorehitpause = 1
;===============================================================================================
;                                         Hyper KO States 
;===============================================================================================
[State -3, VarSet]
type=null;VarSet
trigger1=roundstate=2
var(58)=0

[state -3, VarSet]
type=null;VarSet
triggerall=(var(58)=0)
triggerall=winko
trigger1=stateno=[3000,3999];hyper states
trigger2=stateno=[4000,4499];delayed hyper states
trigger3=stateno=[4600,4799];team hyper state
var(58)=2
ignorehitpause=1

[state -3, helper]
type=null;helper
triggerall=NumHelper(9600)=0
trigger1=var(58)=2
stateno=9600
ID=9600
pos=0,0
postype=p1
helpertype=normal
name="Hko-sounds"
pausemovetime=999
supermovetime=999
ignorehitpause = 1
;================================================================================================
;                                         GetHit Sounds 
;================================================================================================
[State -3, light]
type = PlaySnd
triggerall = stateno = 5000 && life >= 200
trigger1 = anim = 5000 || anim = 5010 || anim = 5020
trigger1 = time = 1
trigger1 = random < 300
value = 2,21

[State -3, light]
type = PlaySnd
triggerall = stateno = 5020 && life >= 200
trigger1 = anim = 5000 || anim = 5010 || anim = 5020
trigger1 = time = 1
trigger1 = random < 300
value = 2,ifelse(random<150,23,22)

[State -3, medium]
type = PlaySnd
triggerall = stateno = 5000 && life >= 200
trigger1 = random < 300
trigger1 = time = 1
trigger1 = anim = 5001 || anim = 5011 || anim = 5021
value = 2,24

[State -3, medium]
type = PlaySnd
triggerall = stateno = 5020 && life >= 200
trigger1 = anim = 5001 || anim = 5011 || anim = 5021
trigger1 = random < 300
trigger1 = time = 1
value = 2,ifelse(random<150,26,25)

[State -3, heavy]
type = PlaySnd
triggerall = stateno = 5000 && life >= 200
trigger1 = random < 300
trigger1 = time = 1
trigger1 = anim = 5002 || anim = 5012 || anim = 5022
value = 2,27

[State -3, heavy]
type = PlaySnd
triggerall = stateno = 5000 && life >= 200
trigger1 = anim = 5002 || anim = 5012 || anim = 5022
trigger1 = random < 300
trigger1 = time = 1
value = 2,ifelse(random<150,29,28)
