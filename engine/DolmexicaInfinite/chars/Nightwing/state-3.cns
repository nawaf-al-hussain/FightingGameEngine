

;=============================================================================================
;           States that are executed when in self's state file (use statedef -3)
;=============================================================================================

[Statedef -3]

[State -3, AssertSpecial]
type = AssertSpecial
trigger1 = RoundState !=2
flag = nobardisplay
ignorehitpause=1

;Remove afterimage
[State 0, AfterImageTime]
type = AfterImageTime
trigger1 = MoveType = H
trigger2 = Stateno < 3000
time = 0

[State 0, PlaySnd]
type = PlaySnd
triggerall = numtarget
triggerall = !(target,ishelper)&& var(35)=20001 && MoveHit && !NumExplod(222)
trigger1 = stateno = [200,220]
trigger2 = stateno = [400,420]
trigger3 = stateno = [600,620]
value = S220,1+random%2
ignorehitpause = 1
persistent = 0

[State 1051, shock]
type = Explod
triggerall = numtarget
triggerall = !(target,ishelper)&& !NumExplod(222) && var(35)=20001 && MoveHit
trigger1 = stateno = [200,220]
trigger2 = stateno = [400,420]
trigger3 = stateno = [600,620]
trigger4 = Stateno = 1600
anim = 222+random%2
ID = 222
postype = P2
pos = 0,-54
pausemovetime = 9999
supermovetime = 9999
sprpriority = 500
bindtime = -1
ownpal = 1
scale =0.55,0.55
removetime=24
ignorehitpause = 1




