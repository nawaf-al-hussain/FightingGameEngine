sysvar(3) = 0
ignorehitpause = 1

[State 6020, 1vs]
type = VarSet
triggerall = HitVel Y > 0
triggerall = GetHitVar(yaccel) > 0
triggerall = HitFall
trigger1 = Pos Y < 0
sysvar(3) = 1
ignorehitpause = 1

[State 6020, 1]
type = ChangeAnim
trigger1 = 1
value = anim

[State 6020, 2]
