Anim=7014
trigger1=time=0
postype=P1
pos=-40,-25
bindTime=1
sprpriority=4
vel=ifelse(frontedgebodydist>=60,3,0),0
scale=.5,.5
ownpal=1
removeongethit=1

[State 0, VarSet]
