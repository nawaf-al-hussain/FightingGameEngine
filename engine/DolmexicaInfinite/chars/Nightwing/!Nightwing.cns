trigger1 = Time = 0
y = 0

[State 6100, 2]
type = VelSet
trigger1 = Time = 0
x = 0
y = 0

[State 6100, 3]
type = ChangeAnim
trigger1 = Anim = 5100 && AnimTime = 0
value = 5110

[State 6100, 4]
type = ChangeState
triggerall = Alive
trigger1 = time >= 22
value = 6120

[State 6100, 5]
type = SelfState
triggerall = !Alive
trigger1 = time >= 15
value = 5150

[State 6110, 6]
