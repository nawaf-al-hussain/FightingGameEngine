;---------------------------------------------------------------------------
; Partner intro state. You can give this state it's own animation if you wan't (I recommend that).
; Add the animation 199 on your character if you wan't, he will jump offscreen when roundstate = 2
; in this state the character stands with the anim 199 (or with his stand anim 0 if he doesn't have the 199)
; and then jumps outside of the screen.
[Statedef 199]
type = S
ctrl = 0

; Velocity applied after the "jump start" animation.
[State 199]
type = VelSet
trigger1 = roundstate=2
x = -12
Y = -6
persistent = 1

; In case the character does have the anim 199.
[State 199]
type = ChangeAnim
triggerall = SelfAnimExist(199)
triggerall = roundsexisted = 0
trigger1 = time = 0
value = 199
persistent = 0

; In case the character doesn't have the anim 199.
[State 199]
type = ChangeAnim
triggerall = !SelfAnimExist(199)
triggerall = roundsexisted = 0
trigger1 = time = 0
value = 0
persistent = 0

; Goes to the jump start animation (anim 40).
[State 199]
type = ChangeAnim
trigger1 = roundstate=2
value = 40
persistent = 0

; Goes to the jump up animation (anim 41).
[State 199]
type = ChangeAnim
trigger1 = roundstate=2
value = 41
persistent = 0

; OPTIONAL: you can add any sound for the jump here. just give it a valid sound value and remove the "null".
[State 199]
type = NULL ;PlaySnd
trigger1 = roundstate=2
value = S100,10        ;Give this a valid sound value.
channel = -1
ignorehitpause = 1
persistent = 0

; Changestate once out of the screen
[State 199]
type = ChangeState
triggerall = roundstate=2
trigger1 = backEdgeDist <= -40
value = 4512

; avoids being in the screen once the character was fighting for more than 1 round (skips the teammate intro).
[State 199]
type = ChangeState
triggerall = roundsexisted != 0
trigger1 = time = 0
value = 4512
