; -----------------------------------------------------------------------
; Flying Screen Effect (Vs series feature, Aerial Rave Only) - by FerchogtX
[Statedef 7500]
type = A
physics = N
ctrl = 0
anim = 9501

[State FS-1, Camera]
type = ScreenBound
trigger1 = 1
value = 1
movecamera = 1, 1

[State FS-1, Get X-Vel]
type = VarSet
triggerall = P2StateNo = 6020
trigger1 = time = 0
fvar(0) = abs(enemy, GetHitVar(xvel))

[State FS-1, Get Y-Vel]
type = VarSet
triggerall = P2StateNo = 6020
trigger1 = time = 0
fvar(1) = (enemy, GetHitVar(yvel))

[State FS-1, Get Y-Accel]
type = VarSet
triggerall = P2StateNo = 6020
trigger1 = time = 0
fvar(2) = (enemy, GetHitVar(yaccel))

[State FS-1, Get Pausetime 1]
type = VarSet
trigger1 = P2StateNo = [6020, 6100]
var(0) = (enemy, GetHitVar(HitShakeTime))

[State FS-1, Get Pausetime 2]
type = VarSet
trigger1 = P2StateNo = 6020
trigger1 = time = 0
var(1) = (enemy, GetHitVar(HitShakeTime)) + 2

[State FS-1, Fix Pos]
type = PosAdd
trigger1 = var(0)
x = -(var(1))

[State FS-1, Set Y-Accel]
type = VelAdd
trigger1 = !var(0)
y = fvar(2)

[State FS-1, Set Velocity]
type = VelSet
trigger1 = !var(0)
x = -(fvar(0))
y = fvar(1)
persistent = 0

[State FS-1, No Movement]
type = VelSet
trigger1 = P2StateNo = 6100
x = 0
y = 0

[State FS-1, End!]
type = DestroySelf
trigger1 = AnimTime = 0
trigger2 = P2StateNo != [6020, 6100]

; -----------------------------------------------------------------------
; Aerial Rave Finisher State (Dash after AR Finisher) - by FerchogtX
[Statedef 7600]
type     = A
movetype = I
physics  = N
ctrl = 0

[State 6500, 2] ;Change to going down anim
type = ChangeAnim
trigger1 = AnimTime = 0
value = 44

[State 6500, 3] ;Don't follow me
type = ScreenBound
trigger1 = 1
value = 0
ignorehitpause = 1

[State 6500, 4] ;Reset My pos to 0
type = VelSet
trigger1 = time >= 0
x = 0
y = 0

[State 6500, 5] ;I'm offscreen
type = PosSet
trigger1 = time >= 0
x = (Pos X - (ScreenPos X + 100)*(facing))
y = 0
ignorehitpause = 1

[State 6500, xR] ;I'm on land
type = StateTypeSet
trigger1 = Pos Y >= 0
statetype = S

[State 6500, 6] ;Dash Onscreen now!!!
type = ChangeState
trigger1 = !var(6)
trigger2 = time >= 200
value = 100
ctrl = 0

