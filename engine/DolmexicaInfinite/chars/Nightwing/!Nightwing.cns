;---------------------------------------------------------------------------
; Aerial Rave Finisher Get Hit State (being hit)
[Statedef 6020]
type    = A
movetype= H
physics = N
velset = 0,0
anim = 5012
facep2 = 1

[State 6020, 1x]
type = ChangeState
triggerall = (RoundState > 1) && (!Alive)
trigger1 = HitShakeOver
value = 5050

[State 6020, 1rs]
type = VarSet
trigger1 = time = 0
sysvar(3) = 0
ignorehitpause = 1

[State 6020, 1vs]
type = VarSet
triggerall = HitVel Y > 0
triggerall = GetHitVar(yaccel) > 0
triggerall = HitFall
trigger1 = Pos Y < 0
sysvar(3) = 1
ignorehitpause = 1

[State 6020, 1]
type = ChangeAnim
trigger1 = 1
value = anim

[State 6020, 2]
type = ChangeState
trigger1 = HitShakeOver
value = 6030

[State 6020, FFB Hard]
type = ForceFeedback
trigger1 = time = 0
persistent = 0
time = 15
waveform = sinesquare
ampl = 140

;---------------------------------------------------------------------------
; Aerial Rave Finisher Get Hit State (going down)
[Statedef 6030]
type    = A
movetype= H
physics = N
ctrl = 0

[State 6030, 1]
type = VelAdd
trigger1 = 1
y = GetHitVar(yaccel)

[State 6030, 2]
type = HitVelSet
trigger1 = Time = 0
x = 1
y = 1

[State 6030, 3a] ;Anim for HIT_BACK/HIT_DIAG_UP
type = ChangeAnim
triggerall = !sysvar(3)
triggerall = GetHitVar(animtype) != 4
trigger1 = (Pos Y >= 0) && (Time = 0)
trigger2 = (Pos Y < 0) && (Time = (ifelse((SysFVar(1) >= 0), 0, 7)))
value = 5030
persistent = 0

[State 6030, 3b] ;Anim for HIT_UP (it HAS to exist)
type = ChangeAnim
triggerall = !sysvar(3)
triggerall = anim != 5030
triggerall = GetHitVar(animtype) = 4
trigger1 = (Pos Y >= 0) && (Time = 0)
trigger2 = (Pos Y < 0) && (Time = (ifelse((SysFVar(1) >= 0), 0, 7)))
value = ifelse(SelfAnimExist(5051), 5051, ifelse(SelfAnimExist(5035), 5035, 5030))
persistent = 0

[State 6030, 5]
type = ChangeState
trigger1 = (Anim = 5030) && (ifelse((HitVel Y > 0), (Vel Y > 0), (Time >= (ifelse((Pos Y < -60), 5, (ifelse((Pos Y = [-60, 60]), 2, 10)))))))
trigger2 = (Anim = 5051) && (Vel Y > 0) && (Time >= 15)
trigger3 = ((Anim != 5030) && (Anim != 5051)) && (Time >= 8)
trigger4 = Pos Y >= 10
trigger5 = sysvar(3)
trigger6 = (!Alive) && (Vel Y > 0)
value = 6050

;---------------------------------------------------------------------------
; HITA_FALL (knocked up, falling, custom version)
[Statedef 6050]
type    = A
movetype= H
physics = N

[State 6050, 2] ;Hit transition
type = ChangeAnim
triggerall = !sysvar(3)
triggerall = time = 0
triggerall = (anim != 5060) && (anim != 5061)
trigger1 = SelfAnimExist(5035)
value = 5035
persistent = 0

[State 6050, 2RX]
type = ChangeAnim
triggerall = anim = 5035
trigger1 = Vel Y < -4
value = anim

[State 6050, 3] ;Change anim when done with transition
type = ChangeAnim
triggerall = (anim != 5060) && (anim != 5061)
trigger1 = Anim = 5035
trigger1 = AnimTime = 0
trigger2 = Anim != 5035
trigger2 = Vel Y > 0
trigger3 = (sysvar(3)) && (!SelfAnimExist(5060))
value = 5050
persistent = 0

[State 6050, 4] ;Coming down anim
type = ChangeAnim
triggerall = SelfAnimExist(5060)
trigger1 = (Anim = 5050) && (AnimTime = 0)
trigger2 = ((Anim = 5051) || (Anim = 5052)) && (Vel Y > 0)
trigger3 = sysvar(3)
value = 5060
persistent = 0

[State 6050, 5] ;Gravity
type = VelAdd
trigger1 = 1
y = GetHitVar(yaccel)

[State 6050, 1rs]
type = VarSet
trigger1 = anim = 5060
sysvar(3) = 0

[State 6050, 6]
type = ChangeState
trigger1 = Vel Y > 0
trigger1 = Pos Y >= 20
value = 6100 ;HIT_BOUNCE

