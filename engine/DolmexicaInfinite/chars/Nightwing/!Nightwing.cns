[Data]
life = 1000
attack =200
defence = 100
fall.defence_up = 50
liedown.time = 20
airjuggle = 16
sparkno = 2
guard.sparkno = 40
KO.echo = 0
volume = 250
IntPersistIndex = 59
FloatPersistIndex = 40

[Size]
xscale = 1                ;Horizontal scaling factor.
yscale = 1                ;Vertical scaling factor.
ground.back=25            ;Player width (back, ground)
ground.front = 25         ;Player width (front, ground)
air.back = 15             ;Player width (back, air)
air.front = 16            ;Player width (front, air)
height = 79               ;Height of player (for opponent to jump over)
attack.dist = 160         ;Default attack distance
proj.attack.dist = 90     ;Default attack distance for projectiles
proj.doscale = 0          ;Set to 1 to scale projectiles too
head.pos = 4,-73          ;Approximate position of head
mid.pos = -1,-45          ;Approximate position of midsection
shadowoffset =0           ;Number of pixels to vertically offset the shadow
draw.offset = 0,0         ;Player drawing offset in pixels (x, y)

[Velocity]
walk.fwd  = 3.2           ;Walk forward
walk.back = -2.4            ;Walk backward
run.fwd  = 4.6, 0         ;Run forward (x, y)
run.back = -4.5,-5.8      ;Hop backward (x, y)
jump.neu = 0,-9.4         ;Neutral jumping velocity (x, y)
jump.back = -3.25         ;Jump back Speed (x, y)
jump.fwd = 3.2            ;Jump forward Speed (x, y)
runjump.back = -4,-8.1    ;Running jump speeds (opt)
runjump.fwd = 4.8,-8.1    ;.




[Movement]
airjump.num = 1           ;Number of air jumps allowed (opt)
airjump.height = 35       ;Minimum distance from ground before you can air jump (opt)
yaccel = .44              ;Vertical acceleration
stand.friction = .85      ;Friction coefficient when standing
crouch.friction = .82     ;Friction coefficient when crouching

;==============================================================================================
;                                               DASHES
;==============================================================================================
;Dash Forward
[Statedef 100]
type    = S
physics = N
anim = 100
ctrl = 0;<------------this has to be set at 0 for the long jump to work
sprpriority = 1

[state 100, 1]
type = posset
trigger1 = 1
y = 0

[state 100, ctrlset for longjump]
type = ctrlset
triggerall = var(53) = 1 ;|| NumPartner = 0
trigger1 = time>=6
value = 1

[state 100, 4]
type = ctrlset
trigger1 = var(53) = 2
trigger1 = time = 0
value = 0

[state 100, 4]
type = varset
trigger1 = var(53) = 2
trigger1 = time = 0
v = 54
value = 1

[State 100, PlaySnd]
type = PlaySnd
trigger1 = time=5
value = S100,0
volume = 0
channel =1

[State 100, 1] ;To start dashing forwards
type = VelSet
trigger1 =time=0
x =9

[State 100, 2] ;Prevent run from canceling into walk
type = AssertSpecial
trigger1 = 1
flag = NoWalk

[State 100, 3] ;Prevent from turning
type = AssertSpecial
trigger1 = 1
flag = NoAutoTurn

[State 100, dash FX]
type=Explod
Anim=7014
trigger1=ifelse(prevstateno=7600,time=2,time=0)
postype=P1
pos=-40,-15
bindTime=1
sprpriority=4
vel=ifelse(frontedgebodydist>=110,3,0),0
scale=.5,.5
ownpal=1
removeongethit=1

[State 100,6];<--------------with ctrl at 0, you need this for the long jump
type =changestate
trigger1 = var(53) = 1; || NumPartner = 0
trigger1 = command = "holdup"
trigger2 = var(53) = 2
;trigger2 = NumPartner && partner,command = "holdup"
value = 40

[State 100, 3] ;
type = ChangeState
trigger1 = AnimTime = 0
value = 101

;---------------------------------------------------------------------------
; RUN_FWD LAND
[Statedef 101]
type    = S
physics = S
anim = 101
sprpriority = 1
;ctrl = 1

[State 101]
type =playsnd
trigger1 = time=0
value=1,34
channel=0

[State 101]
type=VelAdd
triggerall=Vel X >0
trigger1=time >1
x=-.3

[State 101]
type=VelSet
trigger1=animelem>=3
x=0

[State 101]
type=VarSet
trigger1=1
v=50
value=1

[state 101,1]
type = posset
trigger1 =1
y = 0

[State 101] 
type = AssertSpecial
trigger1 = 1
flag = NoWalk

[State 101] 
type = AssertSpecial
trigger1 = 1
flag = NoAutoTurn

[State 101, dash dust]
type=Explod
Anim=ifelse(p2bodydist x>=40,7017,7016)
trigger1=time=0
postype=P1
pos=20,0
bindTime=1
sprpriority=4
vel=0,0
scale=.5,.5
ownpal=1
removeongethit=1

[State 101]
type = ChangeState
trigger1 = animtime = 0
value = 0
ctrl = 1

