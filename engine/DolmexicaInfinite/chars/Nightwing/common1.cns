; Float
[statedef 53]
type    = A
physics = A

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = !time
value = ifelse(var(35)=20002,var(35)+stateno-2,stateno)

[State 0, PlaySnd]
type = PlaySnd
trigger1 = !time
value = S1,16

[State 0, VelAdd]
type = VelAdd
trigger1 = time%2=1
y = -0.55

[State 0, VelSet]
type = VelSet
trigger1 = command = "holdback"
x = -2

[State 0, VelSet]
type = VelSet
trigger1 = command = "holdfwd"
x = 2

[state 50, 12]
type = changestate
trigger1 = vel y > 0
trigger1 = pos y > 0 
value = 52

