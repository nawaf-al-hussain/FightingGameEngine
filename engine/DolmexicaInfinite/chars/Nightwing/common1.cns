physics = C

[State 131, 1]
type = CtrlSet
triggerall = var(53) = 2
trigger1 = time = 0
value =0

[State 131, 1]
type = ChangeAnim
trigger1 = Anim != 131
value = 131

[State 131, Lo to Hi]
type = selfState
triggerall = var(53) = 1 || NumPartner = 0
trigger1 = command != "holddown" 
value = 130

[State 131, Lo to Hi]
type = selfState
triggerall = var(53)=2
trigger1 = NumPartner && partner,command != "holddown" 
value = 130

