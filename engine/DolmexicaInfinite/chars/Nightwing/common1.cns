;---------------------------------------------------------------------------
; stand
[statedef 0]
type = s
physics = s
sprpriority = 0

[State 0, Stop Intro Voices]
type = StopSnd
trigger1 = !time && !ctrl
channel = 10

;[State 0, VarSet]
;type = VarSet
;trigger1 = !time && var(25) = 0
;v = 35
;value = 0
;
;[State 0, VarSet]
;type = VarSet
;trigger1 = !time && var(25) = 1
;v = 35
;value = 1
;
;[State 0, VarSet]
;type = VarSet
;trigger1 = !time && var(25) = 2
;v = 35
;value = 2

[State 0, PlaySnd]
type = PlaySnd
triggerall = var(35) = 20002
trigger1 = AnimElem = 22 || AnimElem = 25 || AnimElem = 28 || AnimElem = 31
value = S3,1

[State 0]
type=stopsnd
trigger1=time>=0
trigger1=prevstateno=[191,196]
channel=0

[State 0]
type=stopsnd
trigger1=time>=0
trigger1=prevstateno=[191,196]
channel=2

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 0]
type = CtrlSet
triggerall = var(53) = 2
trigger1 = time = 0
value = 0

[State 0, 0]
type = CtrlSet
trigger1 = roundstate > 2
value = 1

[State 0, 1]
type = ChangeAnim
trigger1 = Anim != 0 && Anim != 20001 && Anim != 20002 &&Anim != 5
trigger2 = Anim = 5 && AnimTime = 0 ;Turn anim over
value = 0+var(35)

[State 0, Helper]
type = Helper
triggerall = random < 300 && var(35)=20001
trigger1 = AnimElem = 3 || AnimElem = 8
helpertype = normal ;player
name = "spark"
ID = 1
stateno = 1
pos = 6,-78
postype = p1    ;p2,front,back,left,right
facing = 1
keyctrl = 0
ownpal = 1
supermovetime = 0
pausemovetime = 0

[state 0, 2]
type = velset
trigger1 = time = 0
y = 0

[state 0, 3] ;stop moving if low velocity or 4 ticks pass
type = velset
trigger1 = abs(vel x) < 2
trigger2 = time = 4
x = 0

[State 0, 0]
type = ChangeState
triggerall = var(53) = 2
trigger1 = P2Dist X <0
value = 5

;---------------------------------------------------------------------------
; stand fx
[statedef 1]
type = s
physics = s
sprpriority = 5
anim = 222+random%2

[State 0, Trans]
type = Trans
trigger1 = 1 
trans = add

[State 0, VarSet]
type = VarSet
trigger1 = !time
fv = 10    ;fv = 10
value = ifelse(random<500,0.4,0.25)

[State 0, AngleDraw]
type = AngleDraw
trigger1 = 1
value = 1
scale = fvar(10),fvar(10)

[State 0, PlaySnd]
type = PlaySnd
trigger1 = !time;&& random<500
value = S220,3;+random%2


[State 0, DestroySelf]
type = DestroySelf
trigger1 = !AnimTime
trigger2 = Root, MoveType = H
;trigger3 = Root, Stateno !=0

;---------------------------------------------------------------------------
;Turn
[Statedef 5]
type    = S
physics = S
ctrl = 0 
velset = 0,0
sprpriority = 3

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = !time
value = ifelse(var(35)=20002,var(35)+stateno-2,stateno)

[State 11, 1] 
type = CtrlSet
triggerall = var(53) = 1 || NumPartner = 0
trigger1 = time = 0
value = 1

[State 11, 1] 
type = CtrlSet
triggerall = var(53) = 2
trigger1 = time = 0
value = 0

[State 5, turn]
type = Turn
trigger1 = Time = 0
trigger1 = P2Dist X < 0

[State 5, changestate]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1


;---------------------------------------------------------------------------
;Turn
[Statedef 6]
type    = C
physics = C
ctrl = 0 
velset = 0,0
sprpriority = 3

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = !time
value = ifelse(var(35)=20002,var(35)+stateno-2,stateno)

[State 11, 1] 
type = CtrlSet
triggerall = var(53) = 1 || NumPartner = 0
trigger1 = time = 0
value = 1

[State 11, 1] 
type = CtrlSet
triggerall = var(53) = 2
trigger1 = time = 0
value = 0

[State 5, turn]
type = Turn
trigger1 = Time = 0
trigger1 = P2Dist X < 0

[State 5, changestate]
type = ChangeState
trigger1 = AnimTime = 0
value = 10
ctrl = 1
;---------------------------------------------------------------------------
; stand to crouch
[statedef 10]
type    = c
physics = c

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = !time
value = ifelse(var(35)=20002,var(35)+stateno-2,stateno)

[state 10, 1]
type = velmul
trigger1 = time = 0
x = .75

[state 10, 1]
type = velset
trigger1 = time = 0
y = 0

[state 10, 2]
type = changestate
trigger1 = animtime = 0
value = 11

;---------------------------------------------------------------------------
; crouching
[statedef 11]
type    = c
physics = c
sprpriority = 0

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = !time
value = ifelse(var(35)=20002,var(35)+stateno-2,stateno)

[State 0, 4] 
type = Turn
triggerall = var(53)=2
trigger1 = P2Dist X <0

[state 10, 1]
type = velset
trigger1 = time = 0
y = 0
x = 0

[state 11, 1] 
type = changeanim
trigger1 = anim = 6 && animtime = 0
value = 11

[state 11, 1] 
type = changeanim
trigger1 = anim = 20006 && animtime = 0
value = 20011


;---------------------------------------------------------------------------
; Crouch to Stand
[Statedef 12]
type    = S
physics = S

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = !time
value = ifelse(var(35)=20002,var(35)+stateno-2,stateno)

[state 12]
type = velset
trigger1 =1
y = 0

[State 12, 1]
type = ChangeState
trigger1 = AnimTime = 0
value = 0

;---------------------------------------------------------------------------
; Walk
[Statedef 20]
type    = S
physics = S
sprpriority = 0

[State 20,0]
type = CtrlSet
triggerall = var(53) = 2
trigger1 = 1
value =0

[State 20,Assist Trigger]
type =changestate
triggerall = NumPartner
triggerall=var(53)=2
triggerall=partner,stateno=4800
triggerall=(var(49)=0)||(partner,var(49)=0)
triggerall=(time=[0,5])||(partner,time=[0,5])
trigger1=(var(55)=1)||(partner,var(55)=1)
trigger1=(time=[0,5])||(partner,time=[0,5])
value=4900

[State 20,0];
type = VelSet
triggerall = NumPartner
triggerall = var(53) = 2 && partner,stateno!=4511
trigger1 = partner,command = "holdfwd"
x = const(velocity.walk.fwd.x)*ifelse(prevstateno = 5,-1,1)

[State 20,0];
type = VelSet
triggerall = NumPartner
triggerall = var(53) = 2 && partner,stateno!=4511
trigger1 = partner,command = "holdback"
x = const(velocity.walk.back.x)*ifelse(prevstateno = 5,-1,1)

[State 20,0];
type = VelSet
triggerall = NumPartner
triggerall = var(53) = 2 && partner,stateno=4511
trigger1 = partner,command = "holdfwd"
x = const(velocity.walk.fwd.x)*-1

[State 20,0];
type = VelSet
triggerall = NumPartner
triggerall = var(53) = 2 && partner,stateno=4511
trigger1 = partner,command = "holdback"
x = const(velocity.walk.back.x)*-1

[State 20, 1]
type = VelSet
trigger1 = command = "holdfwd" && (var(53) = 1 || NumPartner = 0)
x = const(velocity.walk.fwd.x)

[State 20, 2]
type = VelSet
trigger1 = command = "holdback" && (var(53) = 1 || NumPartner = 0)
x = const(velocity.walk.back.x)

[State 20, 3]
type = ChangeAnim
trigger1 = vel x > 0
trigger1 = Anim != 20 && Anim != 5 && Anim != 20020
trigger2 = Anim = 5 && time >= 5 && command = "holdfwd";AnimTime = 0
value = ifelse(var(35)=20002,var(35)+stateno-2,stateno);20


[State 20, 4]
type = ChangeAnim
trigger1 = vel x < 0
trigger1 = Anim != 21 && Anim != 5 && Anim != 20021
trigger2 = Anim = 5 && time >= 5 && command = "holdback";AnimTime = 0
value = ifelse(var(35)=20002,var(35)+stateno-1,stateno+1);21


;-----------------------------------------------------------------
; Jump Start
[statedef 40]
type    = S
physics = S
anim = 40
ctrl = 0
facep2 = 1
sprpriority = 1

[State 50, Snd]
type=Stopsnd
trigger1=1
trigger1=prevstateno=100
channel=1

[State 40, 1]
type=CtrlSet
trigger1=var(53)=2
trigger1=time=0
value=0

[state 40, 1]
type = velset
trigger1= var(53) = 1 || NumPartner = 0
trigger1 = time = 0
trigger1 = command = "holdback"
trigger1 = prevstateno = 105
trigger2 = var(53) = 2
trigger2 = time = 0
trigger2 = NumPartner && partner,command = "holdback"
trigger2 = prevstateno = 105
x = -6

[state 40, 11]
type = varset
trigger1 = time = 0
var(17) = 0

[state 40, 12]
type = varset
triggerall = var(53) = 1 || NumPartner = 0
trigger1 = command = "DU"
trigger2 = prevstateno =420
var(17) = 1

[state 40, 12]
type = varset
triggerall = var(53) = 2
trigger1 = NumPartner && partner,command = "DU"
trigger2 = prevstateno =420
var(17) = 1

[state 50, playsnd]
type = playsnd
trigger1 = animtime = 0
trigger1 = var(17) = 1
value = s40,0
channel = 0

[state 40, 4]
type = varset
trigger1 = time = 0
sysvar(1) = 0

[state 40, 5]
type = varset
trigger1 = var(53) = 1 || NumPartner = 0
trigger1 = command = "holdfwd"
trigger2 = var(53) = 2
trigger2 = NumPartner && partner,command = "holdfwd"
sysvar(1) = 1

[state 40, 6]
type = varset
trigger1 = var(53) = 1 || NumPartner = 0
trigger1 = command = "holdback"
trigger2 = var(53) = 2
trigger2 = NumPartner && partner,command = "holdback"
sysvar(1) = -1

[state 40, 7]
type = velset
trigger1 = animtime = 0
trigger1 = var(17) = 0
x = ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)

[state 40, 8]
type = velset
trigger1 = animtime = 0
trigger1 = var(17) = 1
x = ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x)*1.1, const(velocity.jump.back.x)*1.1))
y = const(velocity.jump.y)*1.7 ; you can change these value, to make it fit how you want the superjump

[state 40, 9]
type = velset
trigger1 = prevstateno = 100
trigger1 = sysvar(1) = 1
x = const(velocity.runjump.fwd.x)

[State 40, Helper]   ;this determines whether an aerial rave comes into play or not
type = Helper
triggerall = prevstateno = 420 ;include all the states that are launchers
trigger1 = time = 0
helpertype = normal
name = "Rave_Timer"
ID = 7003
stateno =114
pos = 0,0
postype = p1
facing = 1

[state 40, 14]
type = changestate
trigger1 = animtime = 0
value = 50
ctrl = 1
;---------------------------------------------------------------------------
; AirJump Start
[Statedef 45]
type    = A
physics = N
ctrl = 0
velset = 0,0

[State 45, 1]
type = ChangeAnim
trigger1 = SelfAnimExist(44)
value = 44

[State 45, 2]
type = ChangeAnim
trigger1 = !SelfAnimExist(44)
value = 41

[State 45, 3]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 45, 4]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 45, 5]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 45, 6]
type = VelSet
trigger1 = Time = 2
x = ifelse(sysvar(1)=0, const(velocity.airjump.neu.x), ifelse(sysvar(1)=1, const(velocity.airjump.fwd.x), const(velocity.airjump.back.x)))
y = const(velocity.airjump.y)

[State 45, 7]
type = ChangeState
trigger1 = Time = 2
value = 50
ctrl = 1

;---------------------------------------------------------
; jump Up
[statedef 50]
type    = A
physics = A

[State 0, ChangeState]
type = ChangeState
trigger1 = command = "holddown"
value = 53
ctrl = 1

[State 50, Snd]
type=playsnd
trigger1= !time
trigger1= vel x=const(velocity.runjump.fwd.x)
value=S40,1
channel=0

[State 50, Afterimage]
type=afterimage
triggerall= time=1
trigger1= vel x=const(velocity.runjump.fwd.x)
time=2
timegap=1
framegap=4
length=9
palbright=0,0,0
palcontrast=128,128,128
palpostbright=0,0,0
paladd=0,0,0
palmul=.9,.9,.9
trans=add1

[State 50, Afterimage Time]
type=afterimagetime
trigger1= vel y<-1
trigger1= vel x=const(velocity.runjump.fwd.x)
time=2

[state 50, 1]
type = varset
trigger1 = time = 0
sysvar(1) = 0

[state 50, 2]
type=changeanim
triggerall=time=0
;triggerall=ID>partner,ID
trigger1=prevstateno!=[600,655]
trigger2=prevstateno!=5210
value=ifelse((vel x)=0, 41, ifelse((vel x)>0, 42, 43))

[state 50, 2]
type=changeanim
triggerall=time=0
;triggerall=ID>partner,ID
trigger1=prevstateno=[600,655]
trigger2=prevstateno=5210
value=44

[state 50, 2]
type = changeanim
trigger1 = time = 0
;trigger1=ID<partner,ID
value =ifelse((vel x)=0, 41, ifelse((vel x)>0, 42, 43))

[state 50, 4]
type = varset
triggerall = time = 0
trigger1 = vel x = 0
var(1) = 0

[state 50, 5]
type = varset
triggerall = time = 0
trigger1 = vel x > 0
trigger2 = vel x < 0
var(1) = 1

[state 50, 6]
type = turn
trigger1 = p2dist x < 0
trigger1 = var(17) = 1

[state 50, 7]
type = veladd
trigger1 = var(53) = 1 || NumPartner = 0
trigger1 = var(17) = 1
trigger1 = command = "holdback"
trigger1 = vel x > -1.5
trigger2 = var(53) = 2
trigger2 = var(17) = 1
trigger2 = NumPartner && partner,command = "holdback"
trigger2 = vel x > -1.5
x = -.05

[state 50, 8]
type = veladd
trigger1 = var(53) = 1 || NumPartner = 0
trigger1 = var(17) = 1
trigger1 = command = "holdfwd"
trigger1 = vel x < 3
trigger2 = var(53) = 2
trigger2 = var(17) = 1
trigger2 = NumPartner && partner,command = "holdfwd"
trigger2 = vel x < 3
x = .15

[state 52, 4]
type = varset
trigger1 = var(53) = 2
trigger1 = Time = 0
v = 54
value = 1

[state 50, 12]
type = changestate
trigger1 = vel y > 0
trigger1 = pos y > 0 
value = 52

