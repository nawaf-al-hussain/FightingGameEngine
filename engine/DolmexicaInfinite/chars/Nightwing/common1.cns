; GUARD (end)
[Statedef 140]
type = U    ;Leave state type unchanged
physics = U ;Leave physics unchanged
ctrl = 1

[State 140, 1]
type = CtrlSet
triggerall = var(53)= 2
trigger1 = time = 0
value = 0

[State 140, 1]
type = VarSet
triggerall = var(53)=2
trigger1 = time >0
var(54)=1

[State 140, 1]
type = ChangeAnim
trigger1 = Time = 0
value = 140 + (statetype = C) + (statetype = A)*2

[State 140, Hi to Lo]
type = StateTypeSet
triggerall = var(53) = 1 || NumPartner = 0
trigger1 = statetype = S && command = "holddown"
statetype = C
physics = C

[State 140, Lo to Hi]
type = StateTypeSet
triggerall = var(53) = 1 || NumPartner = 0
trigger1 = statetype = C && command != "holddown"
statetype = S
physics = S

[State 140, Hi to Lo]
type = StateTypeSet
triggerall = var(53)=2
trigger1 = statetype = S && NumPartner && partner,command = "holddown"
statetype = C
physics = C

[State 140, Lo to Hi]
type = StateTypeSet
triggerall = var(53)=2
trigger1 = statetype = C && NumPartner && partner,command != "holddown"
statetype = S
physics = S

