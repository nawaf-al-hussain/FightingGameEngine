; jump land
[statedef 52]
type    = S
physics = S
velset = 0,0
ctrl = 1

;[state 52];KEEPS PARTNER IN A GUARDING STATE WHEN LANDING IF PARTNER WAS IN A GUARDING STATE BEFORE LANDING
;type =changestate
;trigger1 = NumPartner && partner,command="holdback"
;trigger1 = prevstateno=[140,155]
;trigger1 = var(53) = 2
;trigger1 = time = 0
;value=120


[State 52]
type = NotHitBy
trigger1 = prevstateno=[140,155]
trigger1 = var(53) = 2
trigger1 = time = 0
value = SCA
time=4

[state 52, 4]
type = ctrlset
trigger1 = var(53) = 2
trigger1 = time = 0
value = 0

[state 52, 4]
type = varset
trigger1 = var(53) = 2
trigger1 = time = 0
v = 54
value = 1

[State 52]
type = turn
trigger1 = p2dist X <= -1
trigger1 = time >= 0

[state 52, 1]
type = changeanim
trigger1 = time = 0
value = 47

[State 52]
type=PlaySnd
trigger1=Time=0
value=47,0
channel=0

[State 52, Dust]
type=Explod
anim=7008
trigger1=Time=0
postype=P1
pos=0,0
persistent=0
sprpriority=-5
pausemovetime=999
supermovetime=999
ownpal = 1

[state 52, 3]
type = posset
trigger1 = time = 0
y = 0

[state 52, 5]
type = changestate
trigger1 = animtime = 0
value = 0
ctrl = 1

;-------------------------------------------------------------------------
;--------------Super Jump By Fallen_Angel
[Statedef 80]
type = A
movetype = I
physics = N
anim = 40
velset = 0,0
ctrl = 0

[State 80, 4]
type = VelSet
triggerall= !(AiLevel)
trigger1 = animtime = 0
x = const(velocity.jump.fwd.x)*1.1
y = const(velocity.jump.y)*1.7 ; you can change these value, to make it fit how you want the superjump

[State 80, 4]
type = VelSet
triggerall= roundstate = 2 && (AiLevel)
trigger1 = !Time
x = const(velocity.jump.neu.x)+2
y = -13;const(velocity.jump.y)*1.7 ; you can change these value, to make it fit how you want the superjump

[State 80, 5]
type = ChangeState
trigger1 = animtime = 0 ;&& !(AiLevel)
value = 50
ctrl = 1

;---------------------------------------------------------------------------
; RUN_FWD
[Statedef 100]
type    = S
physics = S
sprpriority = 1

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = !time
value = ifelse(var(35)=20002,var(35)+stateno-2,stateno)


[state 0, 1]
type = posset
trigger1 = 1
y = 0

[State 100, 1]
type = VelSet
trigger1 = 1
x = const(velocity.run.fwd.x)

[State 100, 2] ;Prevent run from canceling into walk
type = AssertSpecial
trigger1 = 1
flag = NoWalk

[State 100, 3] ;Prevent from turning
type = AssertSpecial
trigger1 = 1
flag = NoAutoTurn

[State 100]
type = ChangeState
triggerall = Time >= 0
trigger1 = command = "holdback"
value = 120 
ctrl = 1

[State 100, 4]
type = ChangeState
trigger1 = command != "holdfwd"
value = 0

